# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# Defaults (can be overridden per campaign)
DEFAULT_FROM_NAME=TES Campaigns
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Rate limiting (emails per second)
SEND_RATE=2

# Next.js app callback (to update recipient status)
NEXTJS_APP_URL=http://localhost:3000
